# ==============================================================================
# DEVMIND ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and configure your keys before running DevMind.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Provider Configuration
# ------------------------------------------------------------------------------
# We support 'groq', 'anthropic', 'openai', and 'ollama'
LLM_PROVIDER="groq"

# Your Groq API Key (obtain from https://console.groq.com/keys)
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Model selection. Examples for Groq:
# - groq/llama-3.3-70b-versatile (Recommended for general reasoning)
# - groq/llama-3.1-8b-instant (Fast, light)
LLM_MODEL="groq/llama-3.3-70b-versatile"


# ------------------------------------------------------------------------------
# Embedding & Vector Configuration
# ------------------------------------------------------------------------------
# We use 'fastembed' by default for local, CPU-based free embedding generation.
# Other options: 'ollama', 'openai'
EMBEDDING_PROVIDER="fastembed"

# Default model for Fastembed (BAAI/bge-small-en-v1.5)
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# Dimensionality of the embedding model:
# BAAI/bge-small-en-v1.5 outputs 384 dimensions.
# nomic-embed-text (Ollama) outputs 768 dimensions.
# text-embedding-3-small (OpenAI) outputs 1536 dimensions.
EMBEDDING_DIMENSIONS="384"


# ------------------------------------------------------------------------------
# Optional: Local Ollama Configuration (For 100% local, offline operation)
# ------------------------------------------------------------------------------
# To run completely local, uncomment the following and set provider to "ollama":
# LLM_PROVIDER="ollama"
# LLM_MODEL="llama3.1:8b"
# LLM_ENDPOINT="http://localhost:11434/v1"
# LLM_API_KEY="ollama"
#
# EMBEDDING_PROVIDER="ollama"
# EMBEDDING_MODEL="nomic-embed-text:latest"
# EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
# EMBEDDING_DIMENSIONS="768"
# HUGGINGFACE_TOKENIZER="nomic-ai/nomic-embed-text-v1.5"


# ------------------------------------------------------------------------------
# Database Configurations (Local Defaults)
# ------------------------------------------------------------------------------
# Vector Store: Defaults to local file-based LanceDB
VECTOR_DB_PROVIDER="lancedb"

# Graph Store: Defaults to local file-based Kuzu
GRAPH_DATABASE_PROVIDER="kuzu"
